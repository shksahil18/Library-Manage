@model LibraryManagementSystem.Models.Author

@{
    ViewData["Title"] = "Author Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @if (Model != null)
            {
                <div class="card shadow-lg rounded-4 border-0">
                    <div class="card-header bg-primary text-white fs-4">
                        Author Details
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-3">Name</dt>
                            <dd class="col-sm-9">@Model.Name</dd>

                            <dt class="col-sm-3">Country</dt>
                            <dd class="col-sm-9">@Model.Country</dd>

                            <dt class="col-sm-3">Biography</dt>
                            <dd class="col-sm-9">@Model.Biography</dd>
                        </dl>

                        <div class="text-end">
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning text-center">
                    Author not found.
                </div>
                <div class="text-center">
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                </div>
            }
        </div>
    </div>
</div>
