@model LibraryManagementSystem.Models.Author

@{
    ViewData["Title"] = "Delete Author";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<h2>Delete Confirmation</h2>
<p>Are you sure you want to delete the author: <strong>@Model.Name</strong>?</p>

<div>
    <h4>@Model.Name</h4>
    <dl class="row">
        <dt class="col-sm-2">Country</dt>
        <dd class="col-sm-10">@Model.Country</dd>

        <dt class="col-sm-2">Biography</dt>
        <dd class="col-sm-10">@Model.Biography</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this author?');">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
