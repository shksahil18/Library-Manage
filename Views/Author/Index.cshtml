@model IEnumerable<LibraryManagementSystem.Models.Author>
@{
    ViewData["Title"] = "Authors";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h2 class="text-center mb-4">Authors List</h2>

    <div class="mb-3">
        <a asp-controller="Author" asp-action="Create" class="btn btn-success">Create New Author</a>
    </div>

    <table class="table table-bordered table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Country</th>
                <th>Biography</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var author in Model)
            {
                <tr>
                    <td>@author.Name</td>
                    <td>@author.Country</td>
                    <td>@author.Biography</td>
                    <td>
                        <div class="d-flex justify-content-center gap-2">
                            <a asp-action="Details" asp-route-id="@author.Id" class="btn btn-sm btn-info">View</a>
                            <a asp-action="Edit" asp-route-id="@author.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@author.Id" class="btn btn-sm btn-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    td, th {
        vertical-align: middle;
    }
    .btn {
        margin: 2px;
    }
</style>