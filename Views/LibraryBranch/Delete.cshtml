@model LibraryManagementSystem.Models.LibraryBranch

@{
    ViewData["Title"] = "Delete Library Branch";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<h2>Delete LibraryBranch</h2>
<p>Are you sure you want to delete the Customer: <strong>@Model.Name</strong>?</p>


<div>
    <h4>@Model.Name</h4>
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.Id</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this librarybranch?');">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
