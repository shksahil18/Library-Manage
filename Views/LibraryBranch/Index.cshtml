@model IEnumerable<LibraryManagementSystem.Models.LibraryBranch>
@{
    ViewData["Title"] = "Library Branches";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h2 class="text-center mb-4">Available LibraryBranches</h2>

    <div class="mb-3">
        <a asp-controller="LibraryBranch" asp-action="Create" class="btn btn-success">Create New LibraryBranch</a>
    </div>

<table class="table table-bordered table-striped shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var branch in Model)
    {
        <tr>
            <td>@branch.Id</td>
            <td>@branch.Name</td>
            <td>
                <a asp-action="Details" asp-route-id="@branch.Id" class="btn btn-info btn-sm">View</a>
                <a asp-action="Edit" asp-route-id="@branch.Id" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@branch.Id" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
