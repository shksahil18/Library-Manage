@model LibraryManagementSystem.Models.LibraryBranch

@{
    ViewData["Title"] = "Branch Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<h2 class="mt-3">@Model.Name</h2>

<p><strong>Branch ID:</strong> @Model.Id</p>

<h4 class="mt-4">Books in this branch:</h4>

@if (Model.Books != null && Model.Books.Any())
{
    <ul class="list-group">
        @foreach (var book in Model.Books)
        {
            <li class="list-group-item">@book.Title</li>
        }
    </ul>
}
else
{
    <p class="text-muted">No books available in this branch.</p>
}

<a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>
