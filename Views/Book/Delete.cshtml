@model LibraryManagementSystem.Models.Book
@{
    ViewData["Title"] = "Delete Book";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<h2>Delete Confirmation</h2>
<p>Are you sure you want to delete the book: <strong>@Model.Title</strong>?</p>

<form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this book?');">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
