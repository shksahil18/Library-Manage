@model LibraryManagementSystem.Models.Customer
@{
    ViewData["Title"] = "Customer Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="card shadow-lg rounded-4">
        <div class="card-header bg-primary text-white fs-4">Customer Details</div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.Phone</dd>

                <dt class="col-sm-3">Membership Date</dt>
                <dd class="col-sm-9">@Model.MembershipDate.ToShortDateString()</dd>

                <dt class="col-sm-3">Membership Plan</dt>
                <dd class="col-sm-9">@Model.Plan</dd>
            </dl>
            <a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>
        </div>
    </div>
</div>
