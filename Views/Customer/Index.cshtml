@model IEnumerable<LibraryManagementSystem.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h2 class="text-center mb-4">Available Customers</h2>

    <div class="mb-3">
        <a asp-controller="customer" asp-action="Create" class="btn btn-success">Create New Customer</a>
    </div>

    <!-- ✅ Borrow Book button ABOVE the table -->
    <a asp-controller="customer" asp-action="BorrowBook" class="btn btn-info text-white mb-3">Borrow Book</a>

<table class="table table-bordered table-striped shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Membership Date</th>
            <th>Membership Plan</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@customer.Name</td>
                <td>@customer.Email</td>
                <td>@customer.Phone</td>
                <td>@customer.MembershipDate.ToShortDateString()</td>
                <td>@customer.Plan</td>
                <td>
                    <div class="d-flex justify-content-center gap-2">
                        <a asp-action="Details" asp-route-id="@customer.Id" class="btn btn-sm btn-info">View</a>
                        <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@customer.Id" class="btn btn-sm btn-danger">Delete</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    td, th {
        vertical-align: middle;
    }
    .btn {
        margin: 2px;
    }
</style>