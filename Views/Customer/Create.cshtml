@model LibraryManagementSystem.Models.Customer
@{
    ViewData["Title"] = "Create Customer";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<h2>Create Customer</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Phone"></label>
        <input asp-for="Phone" class="form-control" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>
    <div class="form-group mb-4">
        <label asp-for="MembershipDate" class="form-label"></label>
        <input asp-for="MembershipDate" class="form-control" type="date" />
        <span asp-validation-for="MembershipDate" class="text-danger"></span>
    </div>
    <div class="form-group mb-4">
        <label asp-for="Plan" class="form-label"></label>
        <select asp-for="Plan" class="form-select">
            <option value="">-- Select Plan --</option>
            <option value="Basic">Basic -- 1Month</option>
            <option value="Premium">Premium -- 6Month</option>
            <option value="Gold">Gold -- 1Year</option>
        </select>
        <span asp-validation-for="Plan" class="text-danger"></span>
    </div>
    <br />
    <button type="submit" class="btn btn-primary">Save</button>    
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
