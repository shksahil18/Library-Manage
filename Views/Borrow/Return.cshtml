@model LibraryManagementSystem.Models.Borrow

@{
    ViewData["Title"] = "Return Book";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="card shadow-lg rounded-4">
        <div class="card-header bg-primary text-white fs-4">Return Borrow Details</div>
        <div class="card-body">
            <h5 class="mb-4 text-danger">Are you sure you want to return this book?</h5>

            <dl class="row">
                <dt class="col-sm-3">Customer Name</dt>
                <dd class="col-sm-9">@Model.Customer?.Name</dd>

                <dt class="col-sm-3">Book Title</dt>
                <dd class="col-sm-9">@Model.Book?.Title</dd>

                <dt class="col-sm-3">Borrow Date</dt>
                <dd class="col-sm-9">
                    @{
                        var istBorrowDate = TimeZoneInfo.ConvertTimeFromUtc(
                            Model.BorrowDateTime.ToUniversalTime(),
                            TimeZoneInfo.FindSystemTimeZoneById("India Standard Time")
                        );
                        @istBorrowDate.ToString("dd-MM-yyyy hh:mm tt")
                    }
                </dd>

                <dt class="col-sm-3">Return Date</dt>
                <dd class="col-sm-9">
                    @if (Model.ReturnDate != null)
                    {
                        var istReturnDate = TimeZoneInfo.ConvertTimeFromUtc(
                            Model.ReturnDate.Value.ToUniversalTime(),
                            TimeZoneInfo.FindSystemTimeZoneById("India Standard Time")
                        );
                        @istReturnDate.ToString("dd-MM-yyyy hh:mm tt")
                    }
                    else
                    {
                        <span class="text-muted">Not yet returned</span>
                    }
                </dd>
            </dl>

            <form asp-action="Return" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger me-2">Confirm Return</button>
                <a asp-action="ViewBorrowBook" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
