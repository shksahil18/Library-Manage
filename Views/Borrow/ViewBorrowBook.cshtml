@model IEnumerable<LibraryManagementSystem.Models.ViewModels.BorrowViewModel>

@{
    ViewData["Title"] = "Borrowed Book Records";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<h2 class="mb-4">Borrowed Book Records</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Customer Name</th>
            <th>Book Title</th>
            <th>Borrow Date & Time</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center">No records found.</td>
            </tr>
        }
        else
        {
            int count = 1;
            foreach (var item in Model)
            {
                var indiaTimeZone = TimeZoneInfo.FindSystemTimeZoneById("India Standard Time");
                var istTime = TimeZoneInfo.ConvertTimeFromUtc(item.BorrowDateTime.ToUniversalTime(), indiaTimeZone);
                
                <tr>
                    <td>@count</td>
                    <td>@item.CustomerName</td>
                    <td>@item.BookTitle</td>
                    <td>@istTime.ToString("dd-MM-yyyy hh:mm tt")</td>
                    <td>
                        @if (item.ReturnDate == null)
                        {
                            <a asp-action="Return" asp-route-id="@item.Id" class="btn btn-sm btn-success">Return</a>
                        }
                        else
                        {
                            <span class="text-success">Returned on @item.ReturnDate?.ToString("dd-MM-yyyy hh:mm tt")</span>
                        }

                        <a asp-controller="Borrow" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">View</a>
                        <a asp-controller="Borrow" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-controller="Borrow" asp-action="Delete" asp-route-id="@item.Id"
                           onclick="return confirm('Are you sure you want to delete this record?');"
                           class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
                count++;
            }
        }
    </tbody>
</table>
